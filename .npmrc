# Hoist Prisma packages to the root of node_modules 
# This allows Jest and NestJS to find the client easily despite pnpm's symlinks
public-hoist-pattern[]=@prisma/*
public-hoist-pattern[]=@types/*

# Ensures a strict peer dependency check (good for preventing version mismatches)
strict-peer-dependencies=true

# Useful for monorepos or Docker, ensures engines are resolved consistently
resolution-mode=highest

# Automatically add new packages to package.json
save=true