# Hoist Prisma and Types for visibility
public-hoist-pattern[]=@prisma/*
public-hoist-pattern[]=@types/*

# pnpm 10 security: Allow these to run post-install scripts
only-built-dependencies[]=@prisma/client
only-built-dependencies[]=@prisma/engines
only-built-dependencies[]=prisma
only-built-dependencies[]=bcrypt

strict-peer-dependencies=true
resolution-mode=highest
save=true